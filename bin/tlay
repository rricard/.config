#!/usr/bin/env bash
# tlay — Editor centric tmux layout
#
# Creates the following pane arrangement in the current window:
#
#   +----------------------+----------+
#   |                      |  shell   |
#   |      $EDITOR         |          |
#   |                      +----------+
#   |                      | dune -w  | 16 lines
#   +----------------------+----------+
#          160 cols          (remain)
#
# Usage: tlay

set -euo pipefail

if [ -z "${TMUX:-}" ]; then
  printf 'tlay: must be run inside a tmux session\n' >&2
  exit 1
fi

# Remember the original (left/current) pane and its working directory
orig_pane=$(tmux display-message -p '#{pane_id}')
orig_dir=$(tmux display-message -p '#{pane_current_path}')

# Split right: new pane gets shell+dune, orig stays left
right_pane=$(tmux split-window -h -c "$orig_dir" -P -F '#{pane_id}')

# Resize the left (editor) pane to 160 columns
tmux resize-pane -t "$orig_pane" -x 160

# In the right pane, split off a 16-line dune build pane at the bottom
tmux split-window -t "$right_pane" -v -l 16 -c "$orig_dir"
dune_pane=$(tmux display-message -p '#{pane_id}')

# Start $EDITOR in the left (original) pane
tmux send-keys -t "$orig_pane" "${EDITOR:-vim} ." Enter

# Launch dune build -w in the right-bottom pane
tmux send-keys -t "$dune_pane" 'dune build -w' Enter

# Focus the editor
tmux select-pane -t "$orig_pane"
